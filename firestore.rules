rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// RÈGLES DE SÉCURITÉ FIRESTORE — Cabinet PONCEY LEBAS
//
// DÉPLOIEMENT :
//   npm install -g firebase-tools
//   firebase login
//   firebase deploy --only firestore:rules
//
// PRINCIPE :
//   Seuls les utilisateurs ayant une session Firebase valide (signInAnonymously)
//   peuvent lire ou écrire les données. Sans session, tout accès est refusé —
//   même si quelqu'un possède les clés API.
//
//   Les collections autorisées sont listées explicitement.
//   Toute collection non listée est bloquée par défaut.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Seuls les utilisateurs avec une session Firebase active ont accès
    function isAuth() {
      return request.auth != null;
    }

    // ── Collections de l'application ─────────────────────────────────────────
    match /items/{docId} {
      allow read, write: if isAuth();
    }

    match /clients/{docId} {
      allow read, write: if isAuth();
    }

    match /contrats/{docId} {
      allow read, write: if isAuth();
    }

    match /sinistres/{docId} {
      allow read, write: if isAuth();
    }

    match /sinistresChasse/{docId} {
      allow read, write: if isAuth();
    }

    match /medDossiers/{docId} {
      allow read, write: if isAuth();
    }

    match /activityLog/{docId} {
      allow read, create: if isAuth();
      // Le journal ne peut pas être modifié ni supprimé par l'appli
      allow update, delete: if false;
    }

    // ── Tout le reste est interdit ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
