rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// RÈGLES DE SÉCURITÉ FIRESTORE — Cabinet PONCEY LEBAS
//
// DÉPLOIEMENT :
//   firebase deploy --only firestore:rules
//   (nécessite Firebase CLI : npm install -g firebase-tools)
//
// Ces règles autorisent uniquement les utilisateurs authentifiés (même anonyme)
// à lire et écrire les données. Sans authentification Firebase valide,
// toute requête est rejetée — même si quelqu'un connaît les clés API.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Seuls les utilisateurs authentifiés (signInAnonymously) peuvent accéder
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
